<service>
	<id>stdistribuidoraosserver.exe</id>
	<name>ST Distribuidora - OS Server</name>
	<description>Sistema de Gestao de Ordens de Servico ST Distribuidora</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>C:\Stdistribuidora\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\Stdistribuidora\backend\src\index.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>ST Distribuidora - OS Server wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<env name="NODE_ENV" value="production"/>
	<serviceaccount>
		<domain>DESKTOP-39UIHA5</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\Stdistribuidora\backend</workingdirectory>
</service>